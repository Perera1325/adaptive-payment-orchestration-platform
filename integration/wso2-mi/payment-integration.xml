<api xmlns="http://ws.apache.org/ns/synapse" name="PaymentAPI" context="/process-payment">
    <resource methods="GET">
        <inSequence>

            <call>
                <endpoint>
                    <failover>
                        <endpoint>
                            <http method="get" uri-template="http://127.0.0.1:56379/pay"/>
                        </endpoint>
                        <endpoint>
                            <http method="get" uri-template="http://127.0.0.1:60844/pay"/>
                        </endpoint>
                    </failover>
                </endpoint>
            </call>

            <!-- Explicit failover for HTTP 500 -->
            <filter source="$axis2:HTTP_SC" regex="500">
                <then>
                    <log level="custom">
                        <property name="status" value="Primary service returned 500. Failing over to fallback-service..."/>
                    </log>
                    <call>
                        <endpoint>
                            <http method="get" uri-template="http://127.0.0.1:60844/pay"/>
                        </endpoint>
                    </call>
                </then>
            </filter>

            <respond/>

        </inSequence>
    </resource>
</api>